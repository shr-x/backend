# MongoDB connection string
MONGODB_URI="mongodb://your_mongo_user:password@host:port/database"

# Redis connection for cart and session management
REDIS_URL="redis://default:password@host:port"
REDIS_PASSWORD="your_redis_password"
REDIS_PORT="6379"

# WhatsApp Cloud API Configuration
WHATSAPP_TOKEN="EAAN..." # Permanent Access Token
WHATSAPP_PHONE_NUMBER_ID="123456789"
WHATSAPP_VERIFY_TOKEN="your_custom_verify_token"

# AI Integration (Gemini)
GEMINI_API_KEY="AIza..."

# Production Security
NODE_ENV="production"
FRONTEND_URL="https://your-admin-dashboard.railway.app"
PORT=3001
